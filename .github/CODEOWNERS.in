/docs/functions/k6bundle.md               @grafana/k6-cloud-provisioning
/templates/functions/k6bundle.md.tmpl    @grafana/k6-cloud-provisioning

# generate tooling
/cmd/generate/**                           @grafana/platform-monitoring
/cmd/without-lister/**                     @grafana/platform-monitoring
/pkg/generate/**                           @grafana/platform-monitoring

# doc templates for resources owned by specific teams
/templates/resources/apps_generic_resource.md.tmpl                @grafana/grafana-app-platform-squad
/templates/resources/apps_provisioning_repository_v0alpha1.md.tmpl @grafana/grafana-app-platform-squad
