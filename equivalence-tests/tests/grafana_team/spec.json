{
  "include_files": [],
  "ignore_fields": {
    "state.json": [
      "values.root_module.resources.*.values.id",
      "values.root_module.resources.*.values.team_id",
      "values.root_module.resources.*.values.team_uid"
    ],
    "plan.json": [
      "planned_values.root_module.resources.*.values.id",
      "resource_changes.*.change.after.id"
    ],
    "apply.json": [
      "*.hook.id_value"
    ]
  },
  "commands": [
    {
      "name": "init",
      "arguments": ["init", "-no-color"],
      "capture_output": false
    },
    {
      "name": "plan",
      "arguments": ["plan", "-out=equivalence_test_plan", "-no-color"],
      "capture_output": false
    },
    {
      "name": "apply",
      "arguments": ["apply", "-json", "equivalence_test_plan"],
      "capture_output": true,
      "output_file_name": "apply.json",
      "has_json_output": true,
      "streams_json_output": true
    },
    {
      "name": "show_state",
      "arguments": ["show", "-json"],
      "capture_output": true,
      "output_file_name": "state.json",
      "has_json_output": true,
      "streams_json_output": false
    },
    {
      "name": "show_plan",
      "arguments": ["show", "-json", "equivalence_test_plan"],
      "capture_output": true,
      "output_file_name": "plan.json",
      "has_json_output": true,
      "streams_json_output": false
    }
  ]
}
